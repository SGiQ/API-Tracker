# Postgres connection string used by API-Tracker.
# Local:
APITRACKER_DSN=$env:APITRACKER_DSN = "postgresql://user:pass@host:5432/apitracker"
# Managed (Railway/Neon/Supabase) usually requires TLS -- append sslmode=require:
# APITRACKER_DSN=postgresql://user:pass@host:5432/dbname?sslmode=require
# See DEPLOY.md for provisioning + the connection-pooler gotcha.

# Provider keys for your apps (used by the wrappers / your application code).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# PERPLEXITY_API_KEY=pplx-...
